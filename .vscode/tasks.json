{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure CMake",
            "type": "shell",
            "command": "cmake -S . -B build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake --build build --config Debug",
            "dependsOn": "Configure CMake",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run Game",
            "type": "shell",
            "command": ".\\build\\Debug\\endless_afternoon.exe",
            "dependsOn": "Build Debug",
            "problemMatcher": []
        }
    ]
}